# Configuration de l'environnement pour E-sitrana
# Copiez ce fichier en .env et adaptez les valeurs

# Base de données
DB_HOST=localhost
DB_NAME=E_sitrana_db
DB_USERNAME=esitrana
DB_PASSWORD=E_sitrana@2024!

# Application
APP_NAME=E-sitrana
APP_URL=http://localhost
APP_ENV=development
DEBUG=true

# Sécurité
SESSION_LIFETIME=3600
PASSWORD_MIN_LENGTH=8

# Upload de fichiers
UPLOAD_MAX_SIZE=5242880
UPLOAD_PATH=./uploads/

# Configuration Email
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@esitrana.mg
ADMIN_EMAIL=admin@esitrana.mg
